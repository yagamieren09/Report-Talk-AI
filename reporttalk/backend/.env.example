# IMPORTANT: You need a free MongoDB Atlas cluster to run this.
# 1. Go to https://mongodb.com/atlas and create a free account/cluster
# 2. Get your connection string and replace the placeholder below.
GEMINI_API_KEY=your_gemini_api_key_here
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/reporttalk?retryWrites=true&w=majority
JWT_SECRET=your_super_secret_jwt_key
PORT=3000
